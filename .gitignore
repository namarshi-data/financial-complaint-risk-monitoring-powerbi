# Power BI temporary/cache files
*.pbitmp
*.tmp
*.temp
*.bak
*.log
*.cache
*.lock
*.ldb
*.lck

# Power BI service/local artifacts
.pbi/
PerformanceAnalyzer/
*.daxcache

# Office temp files
~$*
.DS_Store
Thumbs.db

# Raw source data is committed for reproducibility.
!data/raw/
!data/raw/**

# Sample data is allowed.
!data/sample/
!data/sample/**

# Processed/generated files are ignored.
data/processed/*
data/interim/*
data/exports/*
data/output/*
data/outputs/*

# Keep folder structure.
!data/processed/.gitkeep
!data/interim/.gitkeep
!data/exports/.gitkeep
!data/output/.gitkeep
!data/outputs/.gitkeep

# Spreadsheet/source data files

*.xlsx
*.xls
*.xlsm
*.csv.bak

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env
.ipynb_checkpoints/

# OS / editor
.vscode/
.idea/

# Keep PBIX and PDF tracked for portfolio delivery
!powerbi/*.pbix
!reports/*.pdf
