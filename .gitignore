# Power BI temporary/cache files
*.pbitmp
*.tmp
*.temp
*.bak
*.log
*.cache
*.lock
*.ldb
*.lck

# Power BI service/local artifacts
.pbi/
PerformanceAnalyzer/
*.daxcache

# Office temp files
~$*
.DS_Store
Thumbs.db

# Raw and generated data

# Keep folder structure with .gitkeep files only.

data/raw
data/processed
!data/raw/.gitkeep
!data/processed/.gitkeep

# Sample data can be committed.

!data/sample/
!data/sample/.gitkeep

# Spreadsheet/source data files

*.xlsx
*.xls
*.xlsm
*.csv.bak

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env
.ipynb_checkpoints/

# OS / editor
.vscode/
.idea/

# Keep PBIX and PDF tracked for portfolio delivery
!powerbi/*.pbix
!reports/*.pdf
