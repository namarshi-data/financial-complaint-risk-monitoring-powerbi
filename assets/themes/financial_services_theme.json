{
  "name": "Financial Services Risk Analytics Theme",
  "dataColors": [
    "#2563EB",
    "#0F766E",
    "#DC2626",
    "#D97706",
    "#64748B",
    "#7C3AED",
    "#0891B2",
    "#16A34A"
  ],
  "background": "#F8FAFC",
  "foreground": "#111827",
  "tableAccent": "#2563EB",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "fontColor": {
              "solid": {
                "color": "#111827"
              }
            },
            "textSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "fontColor": {
              "solid": {
                "color": "#374151"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "radius": 4
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  },
  "textClasses": {
    "title": {
      "fontSize": 16,
      "fontFace": "Segoe UI Semibold",
      "color": "#111827"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#111827"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#374151"
    }
  }
}